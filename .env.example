# ============================================
# AI & Crypto News Digest - Configurazione
# ============================================

# --- API Keys ---

# OpenAI per riassunti IA (opzionale ma consigliato)
# Crea una key su: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic per riassunti IA (opzionale)
# Crea una key su: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Brave Search API per web search (opzionale)
# Crea una key su: https://api.search.brave.com/
BRAVE_API_KEY=BSA...-...-...-...

# Twitter/X API (opzionale, per monitoraggio KOL)
# X_BEARER_TOKEN=...

# GitHub Token (opzionale, per più rate limit)
# GITHUB_TOKEN=ghp_...


# --- Email Config (se usi l'invio email) ---

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USERNAME=tuoindirizzo@gmail.com
SMTP_PASSWORD=la-tua-app-password
EMAIL_SENDER=nome@dominio.com
EMAIL_RECIPIENT=destinatario@dominio.com


# --- Discord Webhook (se usi Discord) ---

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...


# --- Generale ---

# Fuso orario
TIMEZONE=Europe/Rome

# Lingua
LANGUAGE=it
